{
    "editor.fontLigatures": true,
    "editor.fontFamily": "Fantasque Sans Mono",
    "editor.fontSize": 16,
    "editor.wordWrap": "on",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "phase",
    "editor.guides.bracketPairsHorizontal": false,
    "editor.guides.bracketPairs": "active",
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.fontFamily": "Fantasque Sans Mono",
    "terminal.integrated.fontSize": 16,
    "terminal.integrated.lineHeight": 1.2,
    "terminal.integrated.showExitAlert": false,
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.suggest.enabled": false,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.initialHint": false,
    "workbench.sideBar.location": "right",
    "workbench.activityBar.location": "top",
    "workbench.panel.showLabels": false,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "workbench.colorTheme": "Omelette",
    "workbench.iconTheme": "Monokai Pro Icons",
    "breadcrumbs.enabled": false,
    "window.menuBarVisibility": "compact",
    "window.commandCenter": false,
    "workbench.reduceMotion": "off",
    "errorLens.fontStyleItalic": true,
    "errorLens.messageBackgroundMode": "message",
    "errorLens.padding": "1",
    "errorLens.codeLensLength": {
        "min": 0
    },
    "errorLens.messageMaxChars": 60,
    "errorLens.border": [
        "1px dashed #fc618d",
        "1px dashed #ffa770",
        "1px dashed",
        "1px dashed"
    ],
    "outline.collapseItems": "alwaysCollapse",
    "editor.smoothScrolling": true,
    "errorLens.decorations": {
        "errorMessage": {
            "textDecoration": ";background:#202020;border-radius:0.6em;padding:0 0.8ch;",
            "color": "#fc618d",
            "fontWeight": "bold"
        },
        "warningMessage": {
            "textDecoration": ";background:#202020;border-radius:0.6em;padding:0 0.8ch;",
            "color": "#ffa770",
            "fontWeight": "bold"
        }
    },
    "errorLens.statusBarColorsEnabled": true,
    "errorLens.statusBarIconsEnabled": true,
    "errorLens.statusBarIconsUseBackground": false,
    "errorLens.editorHoverPartsEnabled": {
        "messageEnabled": false,
        "sourceCodeEnabled": true,
        "buttonsEnabled": false
    }
}